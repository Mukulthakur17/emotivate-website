# Copy to `.env.local` (never commit real secrets).

# Site URL for PayPal return/cancel (no trailing slash). On Vercel set to your domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayPal REST app: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox
