# Copy to `.env.local` (never commit real secrets).

# Site URL for PayPal return/cancel (no trailing slash). On Vercel set to your domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayPal REST app: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox

# Webhook: Developer Dashboard → your app → Webhooks → add URL …/api/paypal/webhook
# Event: PAYMENT.CAPTURE.COMPLETED — copy the Webhook ID here
PAYPAL_WEBHOOK_ID=

# Gmail: use the same inbox as "from". Create an App Password: Google Account → Security → App passwords
SMTP_USER=you.emotivate@gmail.com
SMTP_APP_PASSWORD=
# Where you receive payment alerts (defaults to you.emotivate@gmail.com if unset)
PAYMENT_NOTIFY_EMAIL=you.emotivate@gmail.com
